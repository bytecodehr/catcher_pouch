<div class="w-full">
  <div class="text-sm breadcrumbs mb-6">
    <ul>
      <li><%= link_to "Email Templates", root_path %></li>
      <li><%= @mailer[:mailer_class] %></li>
    </ul>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      <%= @mailer[:mailer_class] %>
    </h1>
  </div>

  <% @mailer[:actions].each do |action| %>
    <% templates = @mailer[:templates].select { |t| t[:action] == action } %>

    <div class="card bg-base-100 shadow-xl mb-4">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <h2 class="card-title text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
            </svg>
            #<%= action %>
          </h2>

          <div class="flex gap-2">
            <% html_template = templates.find { |t| t[:format] == :html } %>
            <% if html_template %>
              <%= link_to template_preview_path(path: html_template[:relative_path]),
                    class: "btn btn-ghost btn-sm gap-1", target: "_blank" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                Preview
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="mt-3">
          <% templates.each do |template| %>
            <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-base-200/50 mb-2">
              <div class="flex items-center gap-2">
                <span class="badge badge-sm <%= template[:format] == :html ? 'badge-primary' : 'badge-ghost' %>">
                  <%= template[:format] %>
                </span>
                <code class="text-sm"><%= template[:filename] %></code>
              </div>
              <div class="flex gap-2">
                <%= link_to template_show_path(path: template[:relative_path]), class: "btn btn-ghost btn-xs gap-1" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                  <%= CatcherPouch.config.editable ? "Edit" : "View" %>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if templates.empty? %>
            <p class="text-sm text-base-content/50 text-center py-2">No template files found for this action.</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
